<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application>
        <receiver
            android:name=".receiver.CopyBroadcastReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="${applicationId}.ACTION_COPY_SCREENSHOT" />
            </intent-filter>
        </receiver>

        <provider
            android:name=".ipc.XposedSecretProvider"
            android:authorities="${applicationId}.secrets"
            android:exported="true" />
    </application>

</manifest>
