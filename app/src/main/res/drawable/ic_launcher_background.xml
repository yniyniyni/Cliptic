<?xml version="1.0" encoding="utf-8"?>
<!--
  Cliptic launcher background — the soft "container → surface" brand backdrop,
  matching the in-app gradient. Uses the Android 12+ Material You system palette
  (@android:color/system_accent1_100 → system_neutral1_50) so it re-tints to the
  wallpaper's dynamic colors by default. The <monochrome> layer (see
  ic_launcher_monochrome.xml) additionally drives the "Themed icons" toggle.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54"
                android:startY="0"
                android:endX="54"
                android:endY="108">
                <item android:offset="0.0" android:color="@android:color/system_accent1_100" />
                <item android:offset="0.55" android:color="@android:color/system_accent1_50" />
                <item android:offset="1.0" android:color="@android:color/system_neutral1_50" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
